server:
  host: 0.0.0.0
  port: 9988
  base_path: /minica

public_base_url: http://127.0.0.1:9988/minica

crl:
  enabled: true
  next_update_days: 30

runtime:
  folder: ./runtime
  db_folder: null

logging:
  file: ./logs/minica.log
  rotate_size_bytes: 10485760
  max_backups: 10
  compress: true

openssl:
  path: /usr/bin/openssl
  # Max wall-clock time for a single openssl command. On expiry the process is
  # terminated (SIGTERM, then SIGKILL) and reaped so nothing escapes. Default 15.
  timeout_seconds: 15
  working_root: ./runtime/openssl-work
  keep_failed_workdirs: false
  # Sweep interval for temporary working directories that were abandoned (e.g.
  # left behind by a crash); successful operations clean up their own workdir.
  reap_after_hours: 24

# Authentication: `users:` (Basic auth) and `headers:` (reverse-proxy header
# auth) can both be configured, each with an `enabled` toggle (default true
# when the section is present). When both are enabled, header identity wins
# when present; Basic auth remains available for requests without identity
# headers, which keeps CLI access usable alongside reverse-proxy SSO.
# At least one mode must be enabled.
#
# Any value in this file may also be written as {{ENV:VAR:default}} to read it
# from an environment variable with a fallback; {{ENV:VAR}} resolves to empty
# when unset. Names/fallbacks are trimmed, and fallback percent escapes are
# decoded on a best-effort basis. See config.yaml.docker for a fully
# parameterised template.
#
# Basic auth — only the bootstrap admin is configured here. All other accounts
# (including viewers) are managed in the database via the Admin Console at
# /minica/admin. The password may be a bcrypt hash (recommended:
# `minica --gen-password`) or plaintext. Plaintext still works but logs a
# warning at startup. (`users:` may be the bare account list, as below, or an
# object with `enabled:` and `list:` keys.)
auth:
  users:
    - username: admin
      password: adminpass
      role: admin

  # Reverse-proxy header auth — trust an authenticating proxy (Authelia,
  # oauth2-proxy, ...) in front of MiniCA to identify users via request
  # headers. No local account is needed; users are managed entirely by the
  # proxy/IdP and there is no login prompt. Only enable this when MiniCA is
  # reachable exclusively through that proxy, or pin the proxy's address with
  # trusted_remotes. When both modes are enabled, requests with this identity
  # header use header auth; requests without it may still use Basic auth.
  #headers:
  #  enabled: true
  #  username: Remote-User        # header carrying the authenticated user id
  #  group: Remote-Groups         # header with the group list; accepts
  #                               # "a,b", "a;b", or a JSON array ["a","b"]
  #  admin_group: admin           # group that grants the admin role
  #  viewer_group: user           # group that grants the viewer role
  #  # Honor identity headers only from these peers (IPs or CIDRs) — typically
  #  # the upstream reverse proxy. Omit or leave empty to trust every remote.
  #  trusted_remotes:
  #    - 127.0.0.1
  #    - 10.0.0.0/8
